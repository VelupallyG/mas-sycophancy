# Copy this file to .env and fill in your values.
# Load with: export $(cat .env | xargs)

# Google Cloud project ID for Vertex AI (required).
GCP_PROJECT=<placeholder>

# Vertex AI region — us-central1 has the broadest Gemini model availability.
GCP_LOCATION=us-central1

# Model ID for all agents. Validated on Concordia v2.4.0.
GEMINI_MODEL_ID=gemini-2.5-flash

# Optional: cap Vertex AI requests per minute (default: 60).
RATE_LIMIT_RPM=60

# Optional: enable TRAIL LLM-as-judge path (post-hoc analysis script).
TRAIL_USE_LLM_JUDGE=false

# TRAIL LLM judge model + deterministic decoding.
TRAIL_JUDGE_MODEL_ID=gemini-2.5-flash
TRAIL_JUDGE_TEMPERATURE=0.0
